              <%= card_dashboard "#{indicator_to_currency @total_notification} Notificações", context_html %>
            <% end %>

            <% if @online_service.present? && @reports.present? && @reports > 0 %>
              <% context_html = '' %>
              <% @range_dates.each do |key| %>
                <% if @online_service.present? && @online_service[key[0]].present? %>
                  <% porcent = sprintf("%0.02f", calculate_percentage_of_values(@online_service[key[0]], key[0] == :year ? @reports : key[0] == :month || key[0] == :last_month ? @online_service[:year] : @online_service[:month])) %>
                  <% context_html += create_progress_bar_dash key[1], @online_service[key[0]], porcent %>
                <% end %>
              <% end %>
              <%= card_dashboard "#{indicator_to_currency @reports} Serviços Prestados Online", context_html %>
            <% end %>

            <p class="dark-gray-color-dashboard mt-2 mx-1 ml-2"><b>* A porcentagem do ano é calculada em função do total, a porcentagem do mês é calculada em função do total anual e a porcentagem da semana é calculada em função do total mensal.</b></p>
          </div>
        </div>
      </div>
    </div>

    <div class="row weekDashOtherIndData">
      <div class="col-12">
        <div class="card-dashboard shadow mb-2">
          <div class="card-header py-3 d-flex flex-row align-items-center justify-content-start">
            <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Indicadores de Uso</h6>
            <i class="fas fa-chart-line fa-2x gray-color-dashboard ml-2"></i>
          </div>
          <div class="row card-body">
            <% if @ten_most_used_requirement.present? || @ten_most_used_monitoring.present? %>
              <div class="col-12 mb-3 px-0 px-sm-3">
                <div class="d-flex flex-row align-items-center justify-content-start mb-3">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <%= @projects_from_friday_to_friday %> Processos foram enviados para a Prefeitura na semana
                  </h6>
                </div>
                <div class="row">
                  <div class="col-12 col-md-6">
                    <% if @ten_most_used_requirement.present? %>
                      <div class="d-flex flex-row align-items-center justify-content-start my-1">
                        <i class="fas fa-file-contract fa-2x gray-color-dashboard mr-2"></i>
                        <p class="m-0 font-weight-bold text-primary-dashboard">Requerimentos mais solicitados</p>
                      </div>
                      <ul class="list-group">
                        <% @ten_most_used_requirement.each do |key, value| %>
                          <li class="list-group-item-dashboard d-flex justify-content-between align-items-center b-0 dark-gray-color-dashboard font-weight-bold">
                            <%= key.capitalize %>
                            <span class="badge badge-pill text-primary-dashboard" style="font-size: 100%"><%= value %></span>
                          </li>
                        <% end %>
                      </ul>
                    <% end %>
                  </div>
                  <div class="col-12 col-md-6">
                    <% if @ten_most_used_monitoring.present? %>
                      <div class="d-flex flex-row align-items-center justify-content-start my-1">
                        <i class="far fa-eye fa-2x gray-color-dashboard mr-2"></i>
                        <p class="m-0 font-weight-bold text-primary-dashboard">Monitoramentos mais executados</p>
                      </div>
                      <ul class="list-group">
                        <% @ten_most_used_monitoring.each do |key, value| %>
                          <li class="list-group-item-dashboard d-flex justify-content-between align-items-center b-0 dark-gray-color-dashboard font-weight-bold">
                            <%= key.capitalize %>
                            <span class="badge badge-pill text-primary-dashboard" style="font-size: 100%"><%= value %></span>
                          </li>
                        <% end %>
                      </ul>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>

            <% if @project_completed_by_agency_and_status_types.present? %>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start mb-3">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <%= @project_completed %> Processos foram concluídos na semana
                  </h6>
                </div>
                <div class="row">
                  <% agencies = [] %>
                  <% @project_completed_by_agency_and_status_types.each_with_index do |(key, data_value), index| %>
                    <% total = (data_value['size_project'].present? ? data_value['size_project'] : data_value[:size_project]) %>
                    <% context_html = '' %>
                    <% agencies << key.to_s %>
                    <% deferred_already_showed = false %>
                    <% data_value.each_with_index do |(key2, data_value2), index2| %>
                      <% if (@status_deferred + [@status_def]).include?(key2.to_s) && !deferred_already_showed %>
                        <% value = 0 %>
                        <% deferred_already_showed = true %>
                        <% (@status_deferred + [@status_def]).each do |st| %>
                          <% value += (data_value[st].present? ? data_value[st].to_i : data_value[st.to_sym].present? ? data_value[st.to_sym].to_i : 0) %>
                        <% end %>
                        <% porcent = sprintf("%0.02f", calculate_percentage_of_values(value, total.to_i).to_f) %>
                        <% bg_color = (@status_color[@status_def].present? && @status_color[@status_def][:background_color].present?) ? @status_color[@status_def][:background_color] : '' %>
                        <% context_html += create_progress_bar_dash @status_def, value, porcent, bg_color %>
                      <% elsif !(@status_deferred + [@status_def, 'size_project']).include?(key2.to_s) %>
                        <% porcent = sprintf("%0.02f", calculate_percentage_of_values(data_value2, total.to_i).to_f) %>
                        <% bg_color = (@status_color[key2.to_s].present? && @status_color[key2.to_s][:background_color].present?) ? @status_color[key2.to_s][:background_color] : '' %>
                        <% context_html += create_progress_bar_dash key2.to_s, data_value2, porcent, bg_color %>
                      <% end %>
                    <% end %>
                    <%= card_dashboard "#{total} #{key}", context_html, class_col: 'col-sm-6 col-lg-4 mb-1' %>
                  <% end %>
                  <div class='col-12 m-2'>
                    <% if (@agencies - agencies).present? %>
                      <p class="dark-gray-color-dashboard mb-0">
                        <b>* <%= (@agencies - agencies).length > 1 ? 'Os Órgãos ' : 'O Órgão ' %>
                          <%= (@agencies - agencies).join(',').gsub(',', ', ') %> não <%= (@agencies - agencies).length > 1 ? 'concluíram' : 'concluiu' %> processos na semana.</b>
                      </p>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="col-lg-12 d-flex justify-content-center p-0 p-sm-2">
              <div class="col-xl-7 mt-3 px-0">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="fas fa-users fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Informações sobre os Usuários do Sistema</h6>
                </div>
                <div class="d-flex justify-content-around mt-2 single-under-line">
                  <div class="text-xs font-weight-bold mb-1 dark-gray-color-dashboard">Ativos: <%= @active_users %></div>
                  <div class="text-xs font-weight-bold mb-1 dark-gray-color-dashboard">Inativos: <%= @inactive_users %></div>
                  <div class="text-xs font-weight-bold mb-1 dark-gray-color-dashboard">Bloqueados: <%= @blocked_users %></div>
                </div>
                <div class="d-flex p-2 bd-highlight justify-content-center font-weight-bold text-primary-dashboard">Total: <%= @users %></div>
                <div class="col-12 pie-chart-dashboard">
                  <%= pie_chart @users_by_type, donut: true, id: 'chartWeeklyDashboard', legend: "right", label: 'Valor', thousands: ".", library: { plotOptions: { pie: { dataLabels: { enabled: false }, showInLegend: true } }, legend: { labelFormat: '{name} : {y} ({percentage:.1f}%)' } } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="alert alert-info text-center mt-4">
      Selecione um intervalo de datas para carregar os indicadores.
    </div>

    <%= form_with url: admin_weekly_dashboards_path, method: :get, local: true, class: "mb-3" do %>
      <div class="row align-items-end">
        <div class="col-12 col-md-5">
          <%= label_tag :initial_date, "Data inicial" %>
          <%= date_field_tag :initial_date, params[:initial_date], class: "form-control" %>
        </div>

        <div class="col-12 col-md-5">
          <%= label_tag :final_date, "Data final" %>
          <%= date_field_tag :final_date, params[:final_date], class: "form-control" %>
        </div>

        <div class="col-12 col-md-2 mt-3 mt-md-0">
          <%= submit_tag "Filtrar", class: "btn btn-primary btn-block" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<%= hidden_field_tag 'city-hall-initial-date', Project.first.created_at.try(:strftime, "%d-%m-%Y") if Project.first.present? %>
