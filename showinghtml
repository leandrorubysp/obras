<div class="container-fluid">
  <div class="d-flex flex-row double-under-lines mb-2 mt-4">
    <%= image_tag @image_url_base64 %>
    <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'>
      Boletim ACTO
    </h4>
  </div>

  <% if params[:initial_date].present? && params[:final_date].present? %>
    <% initial_dt = Date.parse(params[:initial_date]) rescue nil %>
    <% final_dt = Date.parse(params[:final_date]) rescue nil %>

    <div class="d-flex flex-row-reverse color-default btn-square date-picker date-obras text-primary-dashboard">
      <div>
        <i class="fa fa-calendar"></i>
        <h6 class='ml-auto header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'>
          <% if initial_dt.present? && final_dt.present? %>
            <%= "#{initial_dt.strftime("%B").capitalize} - #{initial_dt.strftime("%d/%m/%Y")} a #{final_dt.strftime("%d/%m/%Y")}" %>
          <% else %>
            <%= "#{Time.zone.now.strftime("%B").capitalize} - #{Project.last_friday.strftime("%d/%m/%Y")} a #{Time.zone.now.strftime("%d/%m/%Y")}" %>
          <% end %>
        </h6>
      </div>
    </div>

    <h4 class="text-center header-navbar mt-2 font-weight-bold text-primary-dashboard">Indicadores do ACTO no seu município</h4>

    <div class="d-flex flex-row align-items-center justify-content-center m-2">
      <%= link_to 'javascript: void(0)', data: { toggle: 'modal', target: "#modalWeeklyDashboardPDF" }, remote: false, class: 'btn btn-sm btn-default m-1 btn-link', title: 'Gerar PDF do Boletim' do %>
        <i class="fas fa-file-pdf"></i>
      <% end %>

      <%= link_to 'javascript: void(0)', data: { toggle: 'modal', target: "#modalWeeklyDashboardXLS" }, remote: false, class: 'btn btn-sm btn-default m-1 btn-link', title: 'Gerar EXCEL do Boletim' do %>
        <i class="fas fa-file-excel"></i>
      <% end %>
    </div>

    <div class="row mt-4">
      <%= card_dashboard_border_left counter_name(2), indicator_to_currency(@project_and_certificate_counter), 'border-left-success', 'fas fa-file-alt fa-2x gray-color-dashboard', 'text-success' %>
      <%= card_dashboard_border_left counter_name(3), indicator_to_currency(@soil_use_counter), 'border-left-success', 'fas fa-check-circle fa-2x gray-color-dashboard', 'text-success' %>
      <%= card_dashboard_border_left "#{counter_name(1)} (m²)", indicator_to_currency(@approved_building_counter), 'border-left-primary', 'fas fa-check-circle fa-2x gray-color-dashboard', 'text-primary' %>
      <%= card_dashboard_border_left "#{counter_name(4)} (m²)", indicator_to_currency(@approved_inhabit_counter), 'border-left-primary', 'fas fa-check-circle fa-2x gray-color-dashboard', 'text-primary' %>
      <%= card_dashboard_border_left 'Processos Concluídos', indicator_to_currency(@project_done_counter), 'border-left-info', 'fas fa-clipboard-list fa-2x gray-color-dashboard', 'text-info' %>
      <%= card_dashboard_border_left 'Usuário Ativos', indicator_to_currency(@active_user_counter), 'border-left-warning', 'fas fa-user-check fa-2x gray-color-dashboard', 'text-warning' %>
      <%= card_dashboard_border_left 'Arquivos Anexos', indicator_to_currency(@project_upload_counter), 'border-left-warning', 'fas fa-file-alt fa-2x gray-color-dashboard', 'text-warning' %>
    </div>

    <h6 class="text-center header-navbar my-3 font-weight-bold text-primary-dashboard" style="text-transform: none !important;"> Principais Indicadores</h6>

    <div class="row">
      <div class='col-12 m-2 text-center'>
        <%= button_tag type: 'button', data: { name: "weekDashMonthData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChartAllDiv' do %>
          <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
            <span>Todos</span>
          </p>
        <% end %>

        <%= button_tag type: 'button', data: { name: "weekDashMonthData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
          <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
            <span>Indicadores de Processos</span>
          </p>
        <% end %>

        <%= button_tag type: 'button', data: { name: "weekDashTaxData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
          <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
            <span>Indicadores de Arrecadação</span>
          </p>
        <% end %>

        <%= button_tag type: 'button', data: { name: "weekDashDimensionsIndData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
          <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
            <span>Indicadores de Projeto Aprovado e Executado</span>
          </p>
        <% end %>

        <%= button_tag type: 'button', data: { name: "weekDashProcessData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
          <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
            <span>Indicadores Semanais</span>
          </p>
        <% end %>

        <%= button_tag type: 'button', data: { name: "weekDashOtherIndData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
          <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
            <span>Indicadores de Uso</span>
          </p>
        <% end %>
      </div>

      <div class="col-12 weekDashMonthData">
        <div class="card-dashboard shadow mb-2">
          <div class="card-header py-3 d-flex flex-row align-items-center justify-content-start">
            <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Indicadores de processos</h6>
            <i class="fas fa-chart-line fa-2x gray-color-dashboard ml-2"></i>
          </div>
          <div class="row card-body">
            <% if @completed_and_sent_of_the_year.present? %>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos Recebidos e Concluídos</h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <%= indicator_to_currency(@completed_and_sent_of_the_year[0][:total]) if @completed_and_sent_of_the_year[0].present? %> Processos Recebidos /
                    <%= indicator_to_currency(@completed_and_sent_of_the_year[1][:total]) if @completed_and_sent_of_the_year[1].present? %> Processos Concluídos
                  </h6>
                </div>
                <div class="col-12 mt-3">
                  <%= column_chart @completed_and_sent_of_the_year, id: 'completedChartWeeklyDashboard', thousands: ".", library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } } %>
                </div>
              </div>
            <% end %>

            <% if @deferred_projects_with_agency_of_the_year.present? %>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos deferidos</h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <% count = 0 %>
                    <% @deferred_projects_with_agency_of_the_year.each { |d| count += d[:total] if d[:total].present? } %>
                    <%= indicator_to_currency count %> Processos
                  </h6>
                </div>
                <div class="mt-3">
                  <%= column_chart @deferred_projects_with_agency_of_the_year, stacked: true, id: 'deferredChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>

            <% if @projects_separated_by_name_and_year.present? %>
              <div class="col-12 d-flex flex-row double-under-lines mb-2 mt-4">
                <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'></h4>
              </div>
              <div class="col-12 m-2 text-center">
                <%= button_tag type: 'button', data: { name: "weekDashMonthData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChartAllDiv' do %>
                  <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
                    <span>Todos</span>
                  </p>
                <% end %>
                <% @projects_separated_by_name_and_year.each do |agency| %>
                  <%= button_tag type: 'button', data: { name: "chartDt#{I18n.transliterate(agency[:name].gsub(' ','').gsub("|",'').gsub('/','').gsub('-',''))}" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
                    <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
                      <span><%= agency[:name] %></span>
                    </p>
                  <% end %>
                <% end %>
              </div>
              <% @projects_separated_by_name_and_year.each do |agency| %>
                <div class="col-12 px-0 px-sm-3 mt-3 chartDt<%= I18n.transliterate(agency[:name].gsub(' ','').gsub("|",'').gsub('/','').gsub('-','')) %>">
                  <div class="d-flex flex-row align-items-center justify-content-start">
                    <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                    <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos por Serviços - <%= agency[:name] %></h6>
                  </div>
                  <div class="d-flex flex-row align-items-center justify-content-end">
                    <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                      <%= indicator_to_currency(agency[:total]) if agency[:total].present? %> Processos
                    </h6>
                  </div>
                  <div class="col-12 mt-3 getAllDivForLabelweekDash">
                    <%= column_chart agency[:data], stacked: true, id: "separedByNameChartWeeklyDashboard#{I18n.transliterate(agency[:name].gsub(' ','').gsub("|",'').gsub('/','').gsub('-',''))}", library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                  </div>
                </div>
              <% end %>
            <% end %>

            <% if @get_status_for_charts_dashboard.present? %>
              <div class="col-12 d-flex flex-row double-under-lines mb-2 mt-4">
                <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'></h4>
              </div>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos por Status</h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <% count = 0 %>
                    <% @get_status_for_charts_dashboard.each { |d| count += d[:total] if d[:total].present? } %>
                    <%= indicator_to_currency count %> Processos
                  </h6>
                </div>
                <div class="col-12 mt-3 getAllDivForLabelweekDash">
                  <%= column_chart @get_status_for_charts_dashboard, stacked: true, id: 'StatusProcessChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>

            <% if @projects_separated_by_building_purpose.present? %>
              <div class="col-12 d-flex flex-row double-under-lines mb-2 mt-4">
                <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'></h4>
              </div>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos por <%= @pf_immobile[:finalidade][:placeholder] %></h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <% count = 0 %>
                    <% @projects_separated_by_building_purpose.each { |d| count += d[:total] if d[:total].present? } %>
                    <%= indicator_to_currency count %> Processos
                  </h6>
                </div>
                <div class="col-12 mt-3 getAllDivForLabelweekDash">
                  <%= column_chart @projects_separated_by_building_purpose, stacked: true, id: 'buildingPurposeChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>

            <% if @projects_separated_by_building_kind.present? %>
              <div class="col-12 d-flex flex-row double-under-lines mb-2 mt-4">
                <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'></h4>
              </div>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos por <%= @pf_immobile[:tipo_de_construcao][:placeholder] %></h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <% count = 0 %>
                    <% @projects_separated_by_building_kind.each { |d| count += d[:total] if d[:total].present? } %>
                    <%= indicator_to_currency count %> Processos
                  </h6>
                </div>
                <div class="col-12 mt-3 getAllDivForLabelweekDash">
                  <%= column_chart @projects_separated_by_building_kind, stacked: true, id: 'buildingKindChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>

            <% if @process_separated_by_technical_analysis.present? %>
              <div class="col-12 d-flex flex-row double-under-lines mb-2 mt-4">
                <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'></h4>
              </div>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Processos por Área de Atuação</h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <% count = 0 %>
                    <% @process_separated_by_technical_analysis.each { |d| count += d[:total] if d[:total].present? } %>
                    <%= indicator_to_currency count %> Processos
                  </h6>
                </div>
                <div class="col-12 mt-3 getAllDivForLabelweekDash">
                  <%= column_chart @process_separated_by_technical_analysis, stacked: true, id: 'TecnicalAnalystChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="row weekDashTaxData">
      <div class="col-12">
        <div class="card-dashboard shadow mb-2">
          <div class="card-header py-3 d-flex flex-row align-items-center justify-content-start">
            <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Indicadores de arrecadação</h6>
            <i class="fas fa-dollar-sign fa-2x gray-color-dashboard ml-2"></i>
          </div>
          <div class="row card-body">
            <div class="col-12">
              <%= create_multiple_progress_bar "#{number_to_currency(@data_for_the_treasury_chart[0].to_a.last[1], unit: "", separator: ",", delimiter: ".", precision: 0)} Pagamentos", @data_for_the_treasury_chart[0] %>
            </div>
            <div class="col-12 text-center">
              <ul class="legend-multiple-bars px-0">
                <li>
                  <span style="background-color: #007bff;"></span>
                  Aguardando Pagamento: <%= number_to_currency(@data_for_the_treasury_chart[0][:"Aguardando Pagamento"], unit: "", separator: ",", delimiter: ".", precision: 0) %>
                </li>
                <li>
                  <span style="background-color: #86b300;"></span>
                  Pagos: <%= number_to_currency(@data_for_the_treasury_chart[0][:"Pagos"], unit: "", separator: ",", delimiter: ".", precision: 0) %>
                </li>
                <li>
                  <span style="background-color: #B1B1B1;"></span>
                  Isentos: <%= number_to_currency(@data_for_the_treasury_chart[0][:"Isentos"], unit: "", separator: ",", delimiter: ".", precision: 0) %>
                </li>
              </ul>
            </div>
            <div class="col-12">
              <%= create_multiple_progress_bar "#{number_to_currency(@data_for_the_treasury_chart[1].to_a.last[1], unit: "R$ ", separator: ",", delimiter: ".")} de Arrecadação", @data_for_the_treasury_chart[1], currency: true %>
            </div>
            <div class="col-12 text-center">
              <ul class="legend-multiple-bars px-0">
                <li>
                  <span style="background-color: #007bff;"></span>
                  Aguardando Pagamento: <%= number_to_currency(@data_for_the_treasury_chart[1][:"Aguardando Pagamento"], unit: "R$ ", separator: ",", delimiter: ".") %>
                </li>
                <li>
                  <span style="background-color: #86b300;"></span>
                  Pagos: <%= number_to_currency(@data_for_the_treasury_chart[1][:"Pagos"], unit: "R$ ", separator: ",", delimiter: ".") %>
                </li>
              </ul>
            </div>

            <% if @get_annual_revenue_chart.present? %>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Arrecadação Mensal (R$)</h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <%= indicator_to_currency(@get_annual_revenue_chart[0][:total].round(2)) if @get_annual_revenue_chart[0] %> Aguardando Pagamento /
                    <%= indicator_to_currency(@get_annual_revenue_chart[1][:total].round(2)) if @get_annual_revenue_chart[0] %> pagos
                  </h6>
                </div>
                <div class="col-12 mt-3 getAllDivForLabelweekDash">
                  <%= column_chart @get_annual_revenue_chart, stacked: true, id: 'annualRevenueChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>

            <% if @data_for_the_treasury_chart_for_agency.present? %>
              <div class="col-12 px-0 px-sm-3 mt-3">
                <div class="d-flex flex-row align-items-center justify-content-start">
                  <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Arrecadação Mensal por Orgão (R$)</h6>
                </div>
                <div class="d-flex flex-row align-items-center justify-content-end">
                  <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">
                    <% count = 0 %>
                    <% @data_for_the_treasury_chart_for_agency.each { |d| count += d[:total].round(2) if d[:total].present? } %>
                    <%= indicator_to_currency count %> Arrecadado
                  </h6>
                </div>
                <div class="col-12 mt-3">
                  <%= column_chart @data_for_the_treasury_chart_for_agency, stacked: true, id: 'treasuryChartWeeklyDashboard', library: { legend: { itemStyle: { color: '#5a5c69', fontWeight: 'bold', fontSize: '12px' } } }, height: "600px" %>
                </div>
              </div>
            <% end %>

            <% if @tributary_separated_by_agency_and_year.present? %>
              <div class="col-12 d-flex flex-row double-under-lines mb-2 mt-4">
                <h4 class='header-navbar d-inline align-self-center text-primary-dashboard ml-1 mb-0'></h4>
              </div>
              <div class="col-12 m-2 text-center">
                <%= button_tag type: 'button', data: { name: "weekDashMonthData" }, class: 'btn btn-sm btn-link buttonSeparedByNameChartAllDiv' do %>
                  <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
                    <span>Todos</span>
                  </p>
                <% end %>
                <% @tributary_separated_by_agency_and_year.each do |agency| %>
                  <%= button_tag type: 'button', data: { name: "chartDt#{I18n.transliterate(agency[:name].gsub(' ','').gsub("|",'').gsub('/','').gsub('-',''))}Tax" }, class: 'btn btn-sm btn-link buttonSeparedByNameChart' do %>
                    <p x="21" style="color:#5a5c69;font-size:12px;font-weight:bold;cursor:pointer;fill:#5a5c69;" text-anchor="start" y="15">
                      <span><%= agency[:name] %></span>
                    </p>
                  <% end %>
                <% end %>
              </div>

              <% @tributary_separated_by_agency_and_year.each do |agency| %>
                <% if agency[:data].present? && agency[:data][0].present? %>
                  <div class="col-12 px-0 px-sm-3 mt-3 chartDt<%= I18n.transliterate(agency[:name].gsub(' ','').gsub("|",'').gsub('/','').gsub('-','')) %>Tax">
                    <div class="d-flex flex-row align-items-center justify-content-start">
                      <i class="far fa-chart-bar fa-2x gray-color-dashboard mr-2"></i>
                      <h6 class="m-0 font-weight-bold text-primary-dashboard" style="text-transform: none !important;">Serviços Arrecadação Mensal (R$) - <%= agency[:name] %> - Lançado</h6>
